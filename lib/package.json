{
  "name": "a2a-bridge",
  "version": "1.1.0",
  "description": "Agent-to-Agent bridge for Claude Code — lets multiple Claude instances discover each other and exchange messages over tmux",
  "type": "module",
  "bin": {
    "a2a": "../bin/a2a",
    "a2a-server": "./a2a-server.mjs",
    "a2a-channel": "./a2a-channel.mjs"
  },
  "scripts": {
    "start": "node a2a-server.mjs",
    "channel": "node a2a-channel.mjs",
    "install-hooks": "node install"
  },
  "keywords": ["claude", "a2a", "agent", "bridge", "tmux"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^3.24.1"
  }
}
