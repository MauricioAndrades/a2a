{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/codex-cli-reference.schema.json",
  "title": "Codex CLI Reference",
  "description": "Structured representation of the Codex CLI command reference, including global flags, command overview rows, command-specific option tables, safety guidance, and related resources.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "howToRead",
    "globalFlagOptions",
    "commandOverview",
    "commandDetails",
    "flagCombinationsAndSafetyTips",
    "relatedResources"
  ],
  "properties": {
    "title": {
      "type": "string",
      "const": "Command line options"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "howToRead": {
      "$ref": "#/$defs/howToRead"
    },
    "globalFlagOptions": {
      "$ref": "#/$defs/globalFlagOptions"
    },
    "commandOverview": {
      "$ref": "#/$defs/commandOverview"
    },
    "commandDetails": {
      "$ref": "#/$defs/commandDetails"
    },
    "flagCombinationsAndSafetyTips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/safetyTip"
      }
    },
    "relatedResources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    }
  },
  "$defs": {
    "howToRead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "configPrecedence",
        "globalFlagPlacement",
        "maturityReference"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "configPrecedence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "configPath",
            "commandLineOverrideSyntax",
            "description",
            "reference"
          ],
          "properties": {
            "configPath": {
              "type": "string",
              "const": "~/.codex/config.toml"
            },
            "commandLineOverrideSyntax": {
              "type": "string",
              "const": "-c key=value"
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "reference": {
              "$ref": "#/$defs/link"
            }
          }
        },
        "globalFlagPlacement": {
          "type": "string",
          "minLength": 1
        },
        "maturityReference": {
          "$ref": "#/$defs/link"
        }
      }
    },
    "commandDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codex",
        "appServer",
        "app",
        "debugAppServerSendMessageV2",
        "debugModels",
        "apply",
        "cloud",
        "completion",
        "features",
        "exec",
        "execpolicy",
        "login",
        "logout",
        "mcp",
        "pluginMarketplace",
        "mcpServer",
        "resume",
        "fork",
        "sandbox",
        "update"
      ],
      "properties": {
        "codex": {
          "$ref": "#/$defs/commandDetailWithoutOptions"
        },
        "appServer": {
          "$ref": "#/$defs/appServerCommandDetail"
        },
        "app": {
          "$ref": "#/$defs/appCommandDetail"
        },
        "debugAppServerSendMessageV2": {
          "$ref": "#/$defs/debugAppServerSendMessageV2CommandDetail"
        },
        "debugModels": {
          "$ref": "#/$defs/debugModelsCommandDetail"
        },
        "apply": {
          "$ref": "#/$defs/applyCommandDetail"
        },
        "cloud": {
          "$ref": "#/$defs/cloudCommandDetail"
        },
        "completion": {
          "$ref": "#/$defs/completionCommandDetail"
        },
        "features": {
          "$ref": "#/$defs/featuresCommandDetail"
        },
        "exec": {
          "$ref": "#/$defs/execCommandDetail"
        },
        "execpolicy": {
          "$ref": "#/$defs/execpolicyCommandDetail"
        },
        "login": {
          "$ref": "#/$defs/loginCommandDetail"
        },
        "logout": {
          "$ref": "#/$defs/commandDetailWithoutOptions"
        },
        "mcp": {
          "$ref": "#/$defs/mcpCommandDetail"
        },
        "pluginMarketplace": {
          "$ref": "#/$defs/pluginMarketplaceCommandDetail"
        },
        "mcpServer": {
          "$ref": "#/$defs/commandDetailWithoutOptions"
        },
        "resume": {
          "$ref": "#/$defs/resumeCommandDetail"
        },
        "fork": {
          "$ref": "#/$defs/forkCommandDetail"
        },
        "sandbox": {
          "$ref": "#/$defs/sandboxCommandDetail"
        },
        "update": {
          "$ref": "#/$defs/commandDetailWithoutOptions"
        }
      }
    },
    "commandDetailWithoutOptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "description"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/knownCommandKey"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "appServerCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/appServerOptions"
            }
          }
        }
      ]
    },
    "appCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/appOptions"
            }
          }
        }
      ]
    },
    "debugAppServerSendMessageV2CommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/debugAppServerSendMessageV2Options"
            }
          }
        }
      ]
    },
    "debugModelsCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/debugModelsOptions"
            }
          }
        }
      ]
    },
    "applyCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/applyOptions"
            }
          }
        }
      ]
    },
    "cloudCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execOptions",
            "listOptions"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "execOptions": {
