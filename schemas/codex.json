            }
          }
        }
      ]
    },
    "featuresCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/featuresOptions"
            }
          }
        }
      ]
    },
    "execCommandDetail": {
      "allOf": [
