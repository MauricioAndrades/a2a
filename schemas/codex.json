          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options",
            "resumeOptions"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/execOptions"
            },
            "resumeOptions": {
              "$ref": "#/$defs/execResumeOptions"
            }
          }
        }
      ]
    },
    "execpolicyCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/execpolicyOptions"
            }
          }
        }
      ]
    },
    "loginCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/loginOptions"
            }
          }
        }
      ]
    },
    "mcpCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commands",
            "addOptions"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "commands": {
              "$ref": "#/$defs/mcpCommands"
            },
            "addOptions": {
              "$ref": "#/$defs/mcpAddOptions"
            }
          }
        }
      ]
    },
    "pluginMarketplaceCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commands"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "commands": {
              "$ref": "#/$defs/marketplaceCommands"
            }
          }
        }
      ]
    },
    "resumeCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "options"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "options": {
              "$ref": "#/$defs/resumeOptions"
            }
          }
        }
      ]
