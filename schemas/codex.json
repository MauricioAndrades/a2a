        "$ref": "#/$defs/option"
      },
      "minItems": 5
    },
    "completionOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 1
    },
    "cloudExecOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 3
    },
    "cloudListOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 4
    },
    "mcpCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subcommandOption"
      },
      "minItems": 6
    },
    "mcpAddOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 4
    },
    "marketplaceCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subcommandOption"
      },
      "minItems": 3
    },
    "commandOverview": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandOverviewItem"
      },
      "minItems": 21
    },
    "commandOverviewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "href",
        "type",
        "description"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/knownCommandKey"
        },
        "href": {
          "$ref": "#/$defs/referenceHref"
        },
        "type": {
          "$ref": "#/$defs/maturity"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownCommandAlias"
          },
          "uniqueItems": true
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "type",
        "description"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/knownOptionKey"
        },
        "type": {
          "$ref": "#/$defs/knownOptionType"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "defaultValue": {
          "$ref": "#/$defs/defaultValue"
        },
        "repeatable": {
          "type": "boolean"
        },
        "deprecated": {
          "type": "boolean"
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownOptionKey"
          },
          "uniqueItems": true
        },
        "conflictsWith": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownOptionKey"
          },
          "uniqueItems": true
        },
        "securityImpact": {
          "$ref": "#/$defs/securityImpact"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "subcommandOption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "description"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/knownSubcommandKey"
        },
        "type": {
          "$ref": "#/$defs/knownOptionType"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "defaultValue": {
          "$ref": "#/$defs/defaultValue"
        },
        "repeatable": {
          "type": "boolean"
        },
        "deprecated": {
          "type": "boolean"
        },
        "requires": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownOptionKey"
          },
          "uniqueItems": true
        },
        "conflictsWith": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownOptionKey"
          },
          "uniqueItems": true
        },
        "securityImpact": {
          "$ref": "#/$defs/securityImpact"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "safetyTip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "danger"
          ]
        },
        "appliesTo": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/knownOptionKey"
          },
          "uniqueItems": true
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "danger",
            "deprecated",
            "experimental"
          ]
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "href"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "defaultValue": {
      "type": "string",
      "minLength": 1
    },
    "maturity": {
      "enum": [
        "stable",
        "experimental",
        "beta"
      ]
    },
    "securityImpact": {
      "enum": [
        "none",
        "grants-additional-write-access",
        "changes-working-directory",
        "enables-live-web-search",
        "bypasses-approvals",
        "bypasses-sandbox",
        "loads-local-config",
        "ignores-local-config",
        "loads-remote-server",
        "sends-auth-token",
        "starts-server",
        "runs-sandboxed-command",
        "reads-secret-from-env",
        "reads-secret-from-file",
        "writes-output-file"
      ]
    },
    "referenceHref": {
      "enum": [
        "/codex/cli/reference#codex-interactive",
        "/codex/cli/reference#codex-app-server",
        "/codex/cli/reference#codex-app",
        "/codex/cli/reference#codex-debug-app-server-send-message-v2",
        "/codex/cli/reference#codex-debug-models",
        "/codex/cli/reference#codex-apply",
        "/codex/cli/reference#codex-cloud",
        "/codex/cli/reference#codex-completion",
