    "sandboxCommandDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/commandDetailBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "macOptions",
            "linuxOptions",
            "windowsOptions"
          ],
          "properties": {
            "key": true,
            "description": true,
            "notes": true,
            "links": true,
            "macOptions": {
              "$ref": "#/$defs/sandboxMacOptions"
            },
            "linuxOptions": {
              "$ref": "#/$defs/sandboxLinuxOptions"
            },
            "windowsOptions": {
              "$ref": "#/$defs/sandboxWindowsOptions"
            }
          }
        }
      ]
    },
    "commandDetailBase": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "key",
        "description"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/knownCommandKey"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "globalFlagOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 17
    },
    "execOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 19
    },
    "appServerOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 7
    },
    "appOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 2
    },
    "debugAppServerSendMessageV2Options": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 1
    },
    "debugModelsOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 1
    },
    "resumeOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 3
    },
    "featuresOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 3
    },
    "execResumeOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 5
    },
    "forkOptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/option"
      },
      "minItems": 3
